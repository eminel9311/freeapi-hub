# ==== HTTP Server ====
HTTP_PORT=8080
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=15s

# ==== Database ====
# Format: postgres://user:password@host:port/dbname?sslmode=disable
DATABASE_URL=postgres://freeapi:freeapi@localhost:5432/freeapi?sslmode=disable

# ==== Redis (optional) ====
# Để trống => app dùng in-memory cache
REDIS_URL=redis://localhost:6379/0

# ==== JWT ====
# Generate secret: openssl rand -base64 32
JWT_SECRET=change-this-to-a-random-32-char-string-min
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=720h

# ==== External APIs (free) ====
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1
COIN_GECKO_BASE_URL=https://api.coingecko.com/api/v3
FRANKFURTER_BASE_URL=https://api.frankfurter.app

# Optional - chỉ cần nếu dùng NewsAPI
NEWS_API_KEY=

# ==== App ====
LOG_LEVEL=info
CACHE_DEFAULT_TTL=5m
RATE_LIMIT_PER_MIN=60
